---
/**
 * Inquiry detail — spec §13.2.
 *
 * Full message, sender contact info, referenced animals linked to
 * their admin edit pages, reply via default mail client (mailto: with
 * pre-composed subject and body — spec §13.2 is explicit that the
 * site does NOT send email on the user's behalf; it opens a draft).
 *
 * Mark-read happens on page load (if status was "unread"). Archive is
 * a form POST. Unarchive similarly for archived rows.
 */
import AdminLayout from "~/layouts/AdminLayout.astro";
import AdminPageHeader from "~/components/admin/AdminPageHeader.astro";
import { requireCapability } from "~/lib/auth/guards";
import { readInquiry, writeInquiry } from "~/lib/overrides";
import { getAnimalLive } from "~/lib/cattle-live";
import { displayName } from "~/lib/derive/naming";

const guard = await requireCapability(Astro, "view-inquiries");
if (guard instanceof Response) return guard;
const user = guard;

const { id } = Astro.params;
const inquiry = id ? await readInquiry(id) : null;
if (!inquiry) {
  return Astro.redirect("/admin/inquiries");
}

// Mark read on view (side effect on load — acceptable for Phase 1;
// Phase 2 could move this to a POST from the client so refresh doesn't
// re-fire the write).
if (inquiry.status === "unread") {
  inquiry.status = "read";
  inquiry.readAt = new Date().toISOString();
  inquiry.readByUserId = user.id;
  await writeInquiry(inquiry);
}

const referencedAnimals = (
  await Promise.all(
    inquiry.referencedAnimalIds.map((animalId) => getAnimalLive(animalId))
  )
).filter((a): a is NonNullable<typeof a> => a !== null);

function fmtFull(iso: string): string {
  return new Date(iso).toLocaleString("en-US", {
    weekday: "short",
    month: "short",
    day: "numeric",
    year: "numeric",
    hour: "numeric",
    minute: "2-digit",
    timeZone: user.timeZone,
  });
}

// Compose mailto reply — subject echoes the original with "Re:" prefix,
// body quotes the original for context.
const replySubject = inquiry.subject.toLowerCase().startsWith("re:")
  ? inquiry.subject
  : `Re: ${inquiry.subject}`;
const replyBody = [
  ``,
  ``,
  `---`,
  `On ${fmtFull(inquiry.receivedAt)}, ${inquiry.senderName} wrote:`,
  ``,
  ...inquiry.message.split("\n").map((line) => `> ${line}`),
].join("\n");

const mailtoUrl = `mailto:${encodeURIComponent(inquiry.senderEmail)}?subject=${encodeURIComponent(replySubject)}&body=${encodeURIComponent(replyBody)}`;

const isArchived = inquiry.status === "archived";
---

<AdminLayout title={inquiry.subject} user={user}>
  <nav class="back-row" aria-label="Back">
    <a href="/admin/inquiries">&lsaquo; Back to inquiries</a>
  </nav>

  <AdminPageHeader
    kicker={`From ${inquiry.senderName}`}
    title={inquiry.subject}
    lead={fmtFull(inquiry.receivedAt)}
  />

  <div class="layout">
    <article class="message-panel">
      <div class="message-body">
        {inquiry.message.split(/\n+/).map((p) => <p>{p}</p>)}
      </div>

      <div class="actions">
        <a href={mailtoUrl} class="primary">
          Reply by email &nearr;
        </a>
        {!isArchived ? (
          <form
            method="POST"
            action={`/api/admin/inquiries/${inquiry.id}/archive`}
            class="inline-form"
          >
            <button type="submit" class="secondary">Archive</button>
          </form>
        ) : (
          <form
            method="POST"
            action={`/api/admin/inquiries/${inquiry.id}/unarchive`}
            class="inline-form"
          >
            <button type="submit" class="secondary">Unarchive</button>
          </form>
        )}
      </div>

      <p class="note">
        Reply opens in your default mail app — the site doesn&rsquo;t send mail
        on your behalf, so your reply comes from your own address with your own
        signature.
      </p>
    </article>

    <aside class="context-panel">
      <section class="card">
        <h2 class="card-title">Sender</h2>
        <dl>
          <div><dt>Name</dt><dd>{inquiry.senderName}</dd></div>
          <div>
            <dt>Email</dt>
            <dd><a href={`mailto:${inquiry.senderEmail}`}>{inquiry.senderEmail}</a></dd>
          </div>
          {inquiry.senderPhone && (
            <div>
              <dt>Phone</dt>
              <dd>
                <a href={`tel:${inquiry.senderPhone.replace(/\s+/g, "")}`}>
                  {inquiry.senderPhone}
                </a>
              </dd>
            </div>
          )}
        </dl>
      </section>

      {referencedAnimals.length > 0 && (
        <section class="card">
          <h2 class="card-title">Referenced animals</h2>
          <ul class="animal-list">
            {referencedAnimals.map((a) => (
              <li>
                <a href={`/admin/herd/${a.id}`}>
                  {displayName(a)} <span class="tag">· #{a.tag}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="card">
        <h2 class="card-title">Status</h2>
        <dl>
          <div>
            <dt>State</dt>
            <dd>{inquiry.status}</dd>
          </div>
          {inquiry.readAt && (
            <div>
              <dt>Read</dt>
              <dd>{fmtFull(inquiry.readAt)}</dd>
            </div>
          )}
        </dl>
      </section>
    </aside>
  </div>
</AdminLayout>

<style>
  .back-row {
    margin-bottom: var(--space-4);
  }

  .back-row a {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-kicker);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-muted);
  }

  .back-row a:hover { color: var(--color-accent); }

  .layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 70rem;
  }

  @media (min-width: 960px) {
    .layout {
      grid-template-columns: 2fr 1fr;
    }
  }

  .message-panel {
    background: var(--color-paper);
    border: 1px solid var(--color-cream-deep);
    border-radius: var(--radius-3);
    padding: var(--space-8);
  }

  .message-body {
    max-width: var(--max-width-prose);
  }

  .message-body p {
    font-family: var(--font-body);
    font-size: var(--font-size-md);
    line-height: var(--line-height-relaxed);
    color: var(--color-ink);
    margin: 0 0 var(--space-4);
    white-space: pre-wrap;
  }

  .message-body p:last-child { margin-bottom: 0; }

  .actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-cream-deep);
    flex-wrap: wrap;
    align-items: center;
  }

  .inline-form { margin: 0; }

  .primary {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: 0.78rem;
    letter-spacing: var(--letter-spacing-cta);
    text-transform: uppercase;
    padding: 0.75rem 1.4rem;
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-1);
    text-decoration: none;
    transition: var(--transition-default);
  }

  .primary:hover {
    background: var(--color-accent-deep);
    border-color: var(--color-accent-deep);
    color: var(--color-bg);
    text-decoration: none;
  }

  .secondary {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: 0.78rem;
    letter-spacing: var(--letter-spacing-cta);
    text-transform: uppercase;
    padding: 0.75rem 1.4rem;
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-1);
    cursor: pointer;
    transition: var(--transition-default);
  }

  .secondary:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .note {
    font-family: var(--font-body);
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    font-style: italic;
    margin: var(--space-4) 0 0;
    max-width: 36rem;
    line-height: var(--line-height-relaxed);
  }

  .context-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .card {
    background: var(--color-paper);
    border: 1px solid var(--color-cream-deep);
    border-radius: var(--radius-3);
    padding: var(--space-5);
  }

  .card-title {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-kicker);
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 var(--space-4);
  }

  .card dl { margin: 0; padding: 0; }

  .card dl > div {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-2) 0;
    border-top: 1px solid var(--color-cream-deep);
  }

  .card dl > div:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .card dt {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-kicker);
    text-transform: uppercase;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .card dd {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--color-ink);
    text-align: right;
    word-break: break-word;
  }

  .animal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .animal-list a {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    color: var(--color-accent);
    text-decoration: none;
  }

  .animal-list a:hover {
    color: var(--color-accent-deep);
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }

  .animal-list .tag {
    font-family: var(--font-body);
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    letter-spacing: var(--letter-spacing-kicker);
    text-transform: uppercase;
  }
</style>
