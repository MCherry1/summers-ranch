---
/**
 * Admin per-animal editor — spec §12.7 (inline edit).
 *
 * Phase 1 full UI lands in the next checkpoint: inline-edit fields
 * with auto-save on blur, per-field audit trail, progressive
 * disclosure, tooltips. For now: read-only view of the record plus
 * a link back to the public front so admins can verify rendering.
 */
import AdminLayout from "~/layouts/AdminLayout.astro";
import AdminPageHeader from "~/components/admin/AdminPageHeader.astro";
import ComingSoon from "~/components/admin/ComingSoon.astro";
import { requireAdmin } from "~/lib/auth/guards";
import { getAnimal } from "~/lib/cattle";
import { displayName } from "~/lib/derive/naming";

const result = await requireAdmin(Astro);
if (result instanceof Response) return result;
const user = result;

const { id } = Astro.params;
const animal = id ? getAnimal(id) : null;

if (!animal) {
  return Astro.redirect("/admin/herd", 302);
}

const name = displayName(animal);
---

<AdminLayout title={`Edit ${name}`} user={user}>
  <AdminPageHeader
    kicker="Admin · Herd"
    title={name}
    lead="Read-only view of this animal's record. Inline editing ships in the next checkpoint."
  />

  <div class="actions">
    <a href={`/herd/${animal.id}`} target="_blank" rel="noopener">
      View public card &nearr;
    </a>
    <a href="/admin/herd">&lsaquo; Back to herd</a>
  </div>

  <ComingSoon
    milestone="inline-edit checkpoint"
    detail="Every field on this page will be click-to-edit, auto-save on blur, with a per-field audit trail and plain-language tooltips. Progressive disclosure will hide irrelevant sections until an animal's state makes them apply."
  />

  <section class="record">
    <h2>Current record</h2>
    <dl>
      <div class="row"><dt>Tag</dt><dd>#{animal.tag}</dd></div>
      {animal.name && <div class="row"><dt>Name</dt><dd>{animal.name}</dd></div>}
      <div class="row"><dt>Sex</dt><dd>{animal.sex}</dd></div>
      <div class="row"><dt>Breed</dt><dd>{animal.breed}</dd></div>
      {animal.dateOfBirth && (
        <div class="row"><dt>DOB</dt><dd>{animal.dateOfBirth}</dd></div>
      )}
      <div class="row"><dt>Status</dt><dd>{animal.currentStatus}</dd></div>
      {animal.registrationNumber && (
        <div class="row"><dt>AHA #</dt><dd>{animal.registrationNumber}</dd></div>
      )}
      {animal.distinction && (
        <div class="row">
          <dt>Distinction</dt>
          <dd>{animal.distinction} ({animal.distinctionYear})</dd>
        </div>
      )}
    </dl>
  </section>
</AdminLayout>

<style>
  .actions {
    display: flex;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
  }

  .record {
    margin-top: var(--space-10);
    max-width: var(--max-width-data);
    background: var(--color-paper);
    border-radius: var(--radius-3);
    padding: var(--space-6);
    border: 1px solid var(--color-cream-deep);
  }

  .record h2 {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-kicker);
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 var(--space-4);
  }

  dl {
    margin: 0;
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 0;
  }

  .row {
    display: contents;
  }

  dt, dd {
    padding: var(--space-3) 0;
    border-top: 1px solid var(--color-cream-deep);
    margin: 0;
  }

  .row:first-child dt,
  .row:first-child dd {
    border-top: 0;
    padding-top: 0;
  }

  dt {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-kicker);
    text-transform: uppercase;
    color: var(--color-muted);
  }

  dd {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    color: var(--color-ink);
  }
</style>
