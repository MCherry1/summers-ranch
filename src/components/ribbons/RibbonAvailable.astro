---
/**
 * Available ribbon — spec §19.1 / §19.3.
 *
 * Diagonal gold ribbon across the top-right corner of a photo. Fires
 * only when animal's status is 'available'. Copy is "AVAILABLE" per
 * §19.3 (industry-correct — not "For Sale"). Lato 10px bold (900),
 * 0.2em tracking, dark-gold text (#2c2416) on a gold gradient.
 *
 * All units in px — iOS text scaling with rem would distort the
 * fixed-size graphic (spec §19.2).
 */
---

<div class="available-ribbon" aria-label="This animal is available for sale">
  <div class="band">
    <span class="text">AVAILABLE</span>
  </div>
</div>

<style>
  .available-ribbon {
    position: absolute;
    top: 0;
    right: 0;
    width: 110px;
    height: 110px;
    pointer-events: none;
    overflow: hidden;
    z-index: var(--z-ribbon);
  }

  .band {
    position: absolute;
    top: 22px;
    right: -38px;
    width: 160px;
    transform: rotate(45deg);
    background: linear-gradient(
      180deg,
      #fff2c4 0%,
      #f0d874 40%,
      #c9a227 75%,
      #9a7a0f 100%
    );
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.4),
      inset 0 -1px 0 rgba(0, 0, 0, 0.15);
    text-align: center;
    padding: 5px 0;
  }

  .text {
    display: inline-block;
    font-family: "Lato", -apple-system, sans-serif;
    font-weight: 900;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: #2c2416;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.35);
    line-height: 1;
  }
</style>
