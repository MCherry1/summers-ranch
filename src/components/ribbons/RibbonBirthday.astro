---
/**
 * Birthday ribbon — spec §19.1 + §3.4.
 *
 * Vertical hanging ribbon, baby pink for female / baby blue for male.
 * Tooltip reads "Happy birthday, [Name] — born [full date]" per §3.4.
 * Pure information — no link inside (there's nowhere to navigate for
 * a birthday).
 */
import type { Sex } from "~/schemas";

interface Props {
  sex: Sex;
  animalName: string | null;
  dateOfBirth: string | null;
  leftPx?: number;
}

const { sex, animalName, dateOfBirth, leftPx = 12 } = Astro.props;

const isGirl = sex === "cow" || sex === "heifer";
const palette: "girl" | "boy" = isGirl
  ? "girl"
  : sex === "bull" || sex === "steer"
    ? "boy"
    : "girl";

const happy = "HAPPY".split("");
const birthday = "BIRTHDAY".split("");

const displayName = animalName ?? (sex === "calf" ? "Calf" : sex);
const ariaLabel = `Happy birthday, ${displayName}`;

function fullDate(iso: string | null): string | null {
  if (!iso) return null;
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(iso);
  if (!match) return null;
  const [, yearStr, monthStr, dayStr] = match;
  const year = Number(yearStr);
  const month = Number(monthStr);
  const day = Number(dayStr);
  const MONTHS = [
    "January",
    "February",
    "March",
    "April",
    "May",
    "June",
    "July",
    "August",
    "September",
    "October",
    "November",
    "December",
  ];
  return `${MONTHS[month - 1]} ${day}, ${year}`;
}

const fullDob = fullDate(dateOfBirth);
---

<div class="ribbon-wrap" style={`left: ${leftPx}px;`} data-ribbon-tooltip-wrap>
  <button
    type="button"
    class="ribbon-trigger"
    aria-label={ariaLabel}
    data-ribbon-tooltip-trigger
    aria-expanded="false"
  >
    <div
      class:list={["birthday-ribbon", palette]}
      aria-hidden="true"
    >
      <div class="columns">
        <div class="col">
          {happy.map((letter) => <span class="letter">{letter}</span>)}
        </div>
        <div class="col">
          {birthday.map((letter) => <span class="letter">{letter}</span>)}
        </div>
      </div>
    </div>
  </button>

  <div
    class="tooltip"
    role="tooltip"
    hidden
    data-ribbon-tooltip-panel
  >
    <p class="title">Happy birthday, {displayName}.</p>
    {fullDob && <p class="detail">Born {fullDob}.</p>}
  </div>
</div>

<style>
  .ribbon-wrap {
    position: absolute;
    top: 0;
    z-index: var(--z-ribbon);
  }

  .ribbon-trigger {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
  }

  .birthday-ribbon {
    width: 34px;
    height: 90px;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
    clip-path: polygon(
      0 0,
      100% 0,
      100% calc(100% - 14px),
      50% 100%,
      0 calc(100% - 14px)
    );
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 5px;
    pointer-events: none;
  }

  .birthday-ribbon.girl {
    background:
      linear-gradient(90deg,
        rgba(0,0,0,0.1) 0%,
        rgba(0,0,0,0) 20%,
        rgba(255,255,255,0.12) 50%,
        rgba(0,0,0,0) 80%,
        rgba(0,0,0,0.1) 100%),
      linear-gradient(180deg, #f5dae3 0%, #eabecb 45%, #c48799 100%);
  }

  .birthday-ribbon.boy {
    background:
      linear-gradient(90deg,
        rgba(0,0,0,0.1) 0%,
        rgba(0,0,0,0) 20%,
        rgba(255,255,255,0.12) 50%,
        rgba(0,0,0,0) 80%,
        rgba(0,0,0,0.1) 100%),
      linear-gradient(180deg, #c8dff0 0%, #9ec5e8 45%, #6a9dc4 100%);
  }

  .columns {
    display: flex;
    gap: 3px;
  }

  .col {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .letter {
    font-family: "Cinzel", Georgia, serif;
    font-weight: 700;
    font-size: 7px;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .birthday-ribbon.girl .letter {
    color: #8a5a00;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .birthday-ribbon.boy .letter {
    color: #1e4a7e;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.3);
  }

  .tooltip {
    position: absolute;
    top: 100px;
    left: 0;
    min-width: 220px;
    max-width: 280px;
    padding: 12px 14px;
    background: var(--color-paper);
    border: 1px solid var(--color-cream-deep);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-resting);
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
    color: var(--color-ink);
    line-height: var(--line-height-relaxed);
    z-index: calc(var(--z-ribbon) + 1);
    pointer-events: none;
  }

  .tooltip[data-open] {
    pointer-events: auto;
  }

  .tooltip .title {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    color: var(--color-ink);
    margin: 0 0 var(--space-1);
  }

  .tooltip .detail {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--font-size-xs);
  }
</style>
