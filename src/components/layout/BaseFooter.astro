---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-row">
    <div class="footer-brand">
      <div class="footer-mark">Summers Ranch</div>
      <div class="footer-sub">Sutter Creek · Amador County · California</div>
    </div>
    <nav aria-label="Footer">
      <ul class="footer-links">
        <li><a href="/about">About</a></li>
        <li><a href="/herd">The Herd</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </nav>
    <div class="footer-copy">&copy; {year} Summers Ranch</div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-9);
    padding-block: var(--space-7);
    background: var(--color-earth);
    color: var(--color-cream);
  }
  .footer-row {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }
  .footer-mark {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
  }
  .footer-sub {
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-cream) 65%, transparent);
    margin-top: 4px;
  }
  .footer-links {
    display: flex;
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-links a {
    color: var(--color-cream);
    text-decoration: none;
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 0;
    border-bottom: 1px solid transparent;
  }
  .footer-links a:hover {
    border-bottom-color: var(--color-gold);
  }
  .footer-copy {
    font-size: var(--text-xs);
    color: color-mix(in srgb, var(--color-cream) 65%, transparent);
    text-align: right;
    letter-spacing: 0.06em;
  }
  @media (max-width: 720px) {
    .footer-row {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-links {
      justify-content: center;
      flex-wrap: wrap;
    }
    .footer-copy {
      text-align: center;
    }
  }
</style>
