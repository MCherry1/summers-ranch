---
/**
 * BaseNav — persistent public top nav per spec §10.
 *
 * Items: Home / Herd / Gallery / About / Contact. Desktop: inline row,
 * no chrome, no hamburger. Mobile: collapses to a hamburger disclosure.
 * Type rule (POLISH §7.5 wins over spec §10 for aesthetic detail):
 * Work Sans 500 at --font-size-sm, ink default, burgundy + underline
 * on active, hover darkens color without adding underline.
 */
import { site } from "~/lib/site";

interface Props {
  currentPath: string;   // Astro.url.pathname from the page
}

const { currentPath } = Astro.props;

const items: Array<{ href: string; label: string }> = [
  { href: "/", label: "Home" },
  { href: "/herd", label: "Herd" },
  { href: "/gallery", label: "Gallery" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header class="site-nav">
  <div class="site-nav-inner">
    <a href="/" class="wordmark" aria-label={`${site.ranchName} — home`}>
      {site.ranchName}
    </a>

    <nav aria-label="Primary">
      <button
        class="disclosure"
        type="button"
        aria-expanded="false"
        aria-controls="primary-nav-list"
        data-nav-toggle
      >
        <span class="sr-only">Open menu</span>
        <span class="disclosure-bar" aria-hidden="true"></span>
        <span class="disclosure-bar" aria-hidden="true"></span>
      </button>

      <ul id="primary-nav-list" class="nav-list" data-nav-list>
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={["nav-link", { active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  // Minimal disclosure — no framework needed.
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const list = document.querySelector<HTMLUListElement>("[data-nav-list]");
  if (toggle && list) {
    toggle.addEventListener("click", () => {
      const open = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!open));
      list.toggleAttribute("data-open", !open);
    });
  }
</script>

<style>
  .site-nav {
    border-bottom: 1px solid var(--color-cream-deep);
    background: var(--color-bg);
  }

  .site-nav-inner {
    max-width: var(--max-width-page);
    margin: 0 auto;
    padding: var(--space-4) var(--space-6);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-normal);
    color: var(--color-ink);
    text-decoration: none;
    letter-spacing: var(--letter-spacing-tight);
  }

  .wordmark:hover {
    color: var(--color-ink);
    text-decoration: none;
  }

  nav {
    display: contents;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-6);
  }

  .nav-link {
    font-family: var(--font-body);
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
    color: var(--color-ink);
    text-decoration: none;
    padding: var(--space-2) 0;
    transition: var(--transition-default);
  }

  .nav-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.3em;
  }

  /* Mobile disclosure — hidden on desktop */
  .disclosure {
    display: none;
    background: none;
    border: 0;
    padding: var(--space-2);
    width: 44px;
    height: 44px;   /* minimum touch target per POLISH §8.2 */
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
  }

  .disclosure-bar {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--color-ink);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 639px) {
    .disclosure {
      display: flex;
    }

    .nav-list {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      padding: var(--space-4) var(--space-6);
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-cream-deep);
      z-index: var(--z-dropdown);
    }

    .nav-list[data-open] {
      display: flex;
    }

    .nav-link {
      padding: var(--space-3) 0;
      font-size: var(--font-size-base);
    }

    .site-nav {
      position: relative;
    }
  }
</style>
