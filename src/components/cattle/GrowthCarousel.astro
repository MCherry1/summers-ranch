---
/**
 * GrowthCarousel — spec §4.2 + §4.3.
 *
 * The card-back corner thumbnail expands on tap into a chronological
 * carousel of the animal's timeline-eligible photos. Not a modal —
 * the card-back content behind remains scrollable and readable.
 *
 * Autoplay behavior (§4.3):
 *   - First frame is the most-recent photo (current king-of-the-hill),
 *     held 10 seconds on expand
 *   - Transitions to the oldest chronological photo
 *   - Cycles forward: Live Photo ~2s then still ~4s per slice
 *   - Cycle back to the current-most-recent: extended 10s hold
 *   - Loops indefinitely until paused or collapsed
 *
 * Visible controls:
 *   - Play/pause (top-left)
 *   - Left/right chevrons at edges
 *   - Dot pager along the bottom (one per visible photo)
 *   - Close (top-right)
 *   - Date overlay on each frame
 *
 * Reduced-motion: autoplay defaults to paused, manual advance only.
 *
 * Phase 1 slice selection (§14.10 rubrics deferred to Phase 2): for
 * now, every timeline-eligible photo shows in chronological order.
 * The density buckets will land with the timelineScore rubric.
 */
import type { MediaAsset } from "~/schemas";

interface Props {
  thumbnailSrc: string;      // Shown while collapsed
  placeholderThumb: boolean; // silhouette (contain) vs photo (cover)
  photos: MediaAsset[];      // chronological (oldest first)
  animalName: string;        // for alt / aria
}

const { thumbnailSrc, placeholderThumb, photos, animalName } = Astro.props;

// Order oldest-first for slice iteration; the "current" (most-recent)
// shows first on expand (§4.3 rule 2) and last in the cycle.
const sortedOldestFirst = [...photos].sort(
  (a, b) =>
    new Date(a.capturedAt).getTime() - new Date(b.capturedAt).getTime()
);
const hasPhotos = sortedOldestFirst.length > 0;
const mostRecent = hasPhotos
  ? sortedOldestFirst[sortedOldestFirst.length - 1]!
  : null;

function fmtCaptureDate(iso: string): string {
  const date = new Date(iso);
  const today = new Date();
  const sameYear = date.getFullYear() === today.getFullYear();
  const month = date.toLocaleString("en-US", { month: "long" });
  return sameYear ? month : `${month} ${date.getFullYear()}`;
}

// Serialize frame data for the client-side script via a data attribute
// on the stage, so the script doesn't need a separate fetch.
const frames = sortedOldestFirst.map((asset) => ({
  id: asset.id,
  src: asset.uri,
  mov: asset.livePhotoPair ? `/r2/${asset.livePhotoPair}` : null,
  dateLabel: fmtCaptureDate(asset.capturedAt),
}));
---

<div
  class="carousel-stage"
  data-carousel
  data-frames={JSON.stringify(frames)}
  data-has-photos={hasPhotos ? "true" : "false"}
>
  <button
    type="button"
    class="thumb"
    data-carousel-expand
    aria-label={
      hasPhotos
        ? `View ${animalName}'s growth story`
        : `${animalName} — no photos yet`
    }
    disabled={!hasPhotos}
  >
    <img
      src={thumbnailSrc}
      alt={animalName}
      class:list={["thumb-img", { placeholder: placeholderThumb }]}
    />
  </button>

  {hasPhotos && (
    <div class="expanded" data-carousel-expanded hidden>
      <div class="viewer">
        <img
          class="frame still"
          data-carousel-still
          src={mostRecent!.uri}
          alt={`${animalName} — ${fmtCaptureDate(mostRecent!.capturedAt)}`}
        />
        <video
          class="frame motion"
          data-carousel-motion
          muted
          playsinline
          preload="metadata"
          aria-hidden="true"
        ></video>

        <button
          type="button"
          class="control play-pause"
          data-carousel-play-pause
          aria-label="Pause autoplay"
        >
          <span class="icon" data-playing>
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <rect x="6" y="5" width="4" height="14" fill="currentColor"/>
              <rect x="14" y="5" width="4" height="14" fill="currentColor"/>
            </svg>
          </span>
          <span class="icon" data-paused hidden>
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path d="M8 5v14l11-7z" fill="currentColor"/>
            </svg>
          </span>
        </button>

        <button
          type="button"
          class="control close"
          data-carousel-close
          aria-label="Close growth story"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
            <path d="M6 6l12 12M18 6l-12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>

        <button
          type="button"
          class="chevron prev"
          data-carousel-prev
          aria-label="Previous photo"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          type="button"
          class="chevron next"
          data-carousel-next
          aria-label="Next photo"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <p class="date-overlay" data-carousel-date>
          {fmtCaptureDate(mostRecent!.capturedAt)}
        </p>
      </div>

      <div class="pager" data-carousel-pager>
        {sortedOldestFirst.map((_, i) => (
          <button
            type="button"
            class="dot"
            data-carousel-dot
            data-index={i}
            aria-label={`Photo ${i + 1} of ${sortedOldestFirst.length}`}
          ></button>
        ))}
      </div>
    </div>
  )}
</div>

<script>
  /*
   * Carousel controller. One instance per card back; activated when
   * the user taps the thumb. Iterates through all photos for the
   * animal in chronological order with the pattern specified in
   * §4.3: first frame = current-most-recent held 10s, then hop to
   * oldest, cycle forward through slices at ~6s each (2s motion if
   * available + 4s still), loop back with 10s hold on the current.
   */

  interface Frame {
    id: string;
    src: string;
    mov: string | null;
    dateLabel: string;
  }

  const prefersReducedMotion = matchMedia("(prefers-reduced-motion: reduce)");

  const stages = document.querySelectorAll<HTMLElement>("[data-carousel]");
  stages.forEach(initCarousel);

  function initCarousel(stage: HTMLElement) {
    if (stage.dataset.hasPhotos !== "true") return;
    let frames: Frame[] = [];
    try {
      frames = JSON.parse(stage.dataset.frames ?? "[]") as Frame[];
    } catch {
      return;
    }
    if (frames.length === 0) return;

    const expandBtn = stage.querySelector<HTMLButtonElement>("[data-carousel-expand]")!;
    const expanded = stage.querySelector<HTMLElement>("[data-carousel-expanded]")!;
    const still = stage.querySelector<HTMLImageElement>("[data-carousel-still]")!;
    const motion = stage.querySelector<HTMLVideoElement>("[data-carousel-motion]")!;
    const dateEl = stage.querySelector<HTMLElement>("[data-carousel-date]")!;
    const playPauseBtn = stage.querySelector<HTMLButtonElement>("[data-carousel-play-pause]")!;
    const closeBtn = stage.querySelector<HTMLButtonElement>("[data-carousel-close]")!;
    const prevBtn = stage.querySelector<HTMLButtonElement>("[data-carousel-prev]")!;
    const nextBtn = stage.querySelector<HTMLButtonElement>("[data-carousel-next]")!;
    const dots = Array.from(
      stage.querySelectorAll<HTMLButtonElement>("[data-carousel-dot]")
    );
    const playingIcon = playPauseBtn.querySelector("[data-playing]") as HTMLElement;
    const pausedIcon = playPauseBtn.querySelector("[data-paused]") as HTMLElement;

    const mostRecentIndex = frames.length - 1;
    const STILL_HOLD_MS = 4000;   // slice hold after motion
    const MOTION_MS = 2000;        // Live Photo duration
    const FIRST_HOLD_MS = 10000;   // initial most-recent hold
    const LOOP_HOLD_MS = 10000;    // hold when we land on most-recent at loop

    let currentIndex = mostRecentIndex;
    let autoplay = !prefersReducedMotion.matches;
    let timer: number | undefined;

    function setIcon() {
      playingIcon.toggleAttribute("hidden", !autoplay);
      pausedIcon.toggleAttribute("hidden", autoplay);
      playPauseBtn.setAttribute(
        "aria-label",
        autoplay ? "Pause autoplay" : "Play autoplay"
      );
    }

    function showFrame(index: number) {
      currentIndex = (index + frames.length) % frames.length;
      const frame = frames[currentIndex]!;
      still.src = frame.src;
      still.alt = frame.dateLabel;
      dateEl.textContent = frame.dateLabel;

      // Highlight the corresponding dot
      dots.forEach((dot, i) => {
        if (i === currentIndex) dot.setAttribute("data-active", "true");
        else dot.removeAttribute("data-active");
      });

      // Live Photo motion if available and allowed
      if (frame.mov && !prefersReducedMotion.matches) {
        motion.src = frame.mov;
        motion.currentTime = 0;
        motion.hidden = false;
        motion.removeAttribute("data-finished");
        const playPromise = motion.play();
        if (playPromise && typeof playPromise.catch === "function") {
          playPromise.catch(() => {
            motion.setAttribute("data-finished", "true");
          });
        }
      } else {
        motion.pause();
        motion.removeAttribute("src");
        motion.setAttribute("data-finished", "true");
      }
    }

    function clearTimer() {
      if (timer !== undefined) {
        window.clearTimeout(timer);
        timer = undefined;
      }
    }

    function scheduleNext() {
      clearTimer();
      if (!autoplay) return;

      const currentFrame = frames[currentIndex]!;
      let hold: number;
      if (currentIndex === mostRecentIndex) {
        // Most-recent gets the long hold (first frame or loop landing)
        hold = FIRST_HOLD_MS;
      } else {
        hold = currentFrame.mov && !prefersReducedMotion.matches
          ? MOTION_MS + STILL_HOLD_MS
          : STILL_HOLD_MS;
      }

      timer = window.setTimeout(() => {
        // Advance: after most-recent, jump to oldest (index 0).
        // Otherwise step forward one.
        if (currentIndex === mostRecentIndex) {
          showFrame(0);
        } else {
          showFrame(currentIndex + 1);
          // When we return to most-recent via normal advance, the
          // next scheduleNext() picks up FIRST_HOLD_MS automatically
          // (still 10s but via the LOOP_HOLD semantic — same value).
          void LOOP_HOLD_MS;
        }
        scheduleNext();
      }, hold);
    }

    function togglePlay() {
      autoplay = !autoplay;
      setIcon();
      if (autoplay) scheduleNext();
      else clearTimer();
    }

    function open() {
      expanded.removeAttribute("hidden");
      expandBtn.setAttribute("aria-expanded", "true");
      showFrame(mostRecentIndex);
      setIcon();
      if (autoplay) scheduleNext();
    }

    function close() {
      clearTimer();
      expanded.setAttribute("hidden", "");
      expandBtn.setAttribute("aria-expanded", "false");
      motion.pause();
    }

    expandBtn.addEventListener("click", () => {
      if (expanded.hasAttribute("hidden")) open();
      else close();
    });
    closeBtn.addEventListener("click", close);

    playPauseBtn.addEventListener("click", () => {
      togglePlay();
    });

    prevBtn.addEventListener("click", () => {
      autoplay = false;
      setIcon();
      clearTimer();
      showFrame(currentIndex - 1);
    });
    nextBtn.addEventListener("click", () => {
      autoplay = false;
      setIcon();
      clearTimer();
      showFrame(currentIndex + 1);
    });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        autoplay = false;
        setIcon();
        clearTimer();
        showFrame(i);
      });
    });

    // Reduced-motion starts paused per spec §4.3
    if (prefersReducedMotion.matches) {
      autoplay = false;
    }
  }
</script>

<style>
  .carousel-stage {
    position: relative;
  }

  .thumb {
    display: block;
    width: 84px;
    height: 112px;
    border: 0;
    padding: 0;
    border-radius: var(--radius-3);
    overflow: hidden;
    background: var(--color-cream-deep);
    cursor: pointer;
    transition: var(--transition-default);
  }

  .thumb:hover:not(:disabled) {
    box-shadow: var(--shadow-hover);
  }

  .thumb:disabled {
    cursor: default;
    opacity: 0.85;
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-img.placeholder {
    object-fit: contain;
    padding: 6%;
  }

  .expanded {
    margin-top: var(--space-5);
    background: var(--color-paper);
    border: 1px solid var(--color-cream-deep);
    border-radius: var(--radius-3);
    padding: var(--space-4);
  }

  .viewer {
    position: relative;
    aspect-ratio: 3 / 4;
    background: var(--color-cream-deep);
    border-radius: var(--radius-3);
    overflow: hidden;
  }

  .frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .frame.motion {
    z-index: 2;
    opacity: 1;
    transition: opacity 0.4s ease;
  }

  .frame.motion[data-finished],
  .frame.motion[hidden] {
    opacity: 0;
    pointer-events: none;
  }

  .control {
    position: absolute;
    z-index: 3;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    border: 0;
    padding: 8px;
    border-radius: 50%;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-default);
  }

  .control:hover {
    background: rgba(0, 0, 0, 0.75);
  }

  .control.play-pause {
    top: 12px;
    left: 12px;
  }

  .control.close {
    top: 12px;
    right: 12px;
  }

  .chevron {
    position: absolute;
    z-index: 3;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    border: 0;
    padding: 10px 8px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-default);
    border-radius: 4px;
  }

  .chevron:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .chevron.prev { left: 8px; }
  .chevron.next { right: 8px; }

  .date-overlay {
    position: absolute;
    z-index: 3;
    bottom: 12px;
    left: 12px;
    font-family: var(--font-body);
    font-weight: var(--font-weight-medium);
    font-size: 11px;
    color: rgba(255, 255, 255, 0.9);
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.7),
      0 2px 6px rgba(0, 0, 0, 0.4);
    letter-spacing: 0.02em;
    margin: 0;
  }

  .pager {
    margin-top: var(--space-3);
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    flex-wrap: wrap;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-cream-deep);
    border: 0;
    padding: 0;
    cursor: pointer;
    transition: var(--transition-default);
  }

  .dot:hover {
    background: var(--color-accent-soft);
  }

  .dot[data-active] {
    background: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .frame.motion { display: none; }
  }
</style>
