---
/**
 * ComingSoon — shared admin-surface placeholder for features that
 * have a route + nav entry but whose UI lands in a later push. Keeps
 * the admin shell usable (every nav item resolves) while being
 * explicit about what's real vs coming.
 */
interface Props {
  milestone: string;   // e.g. "inline-edit checkpoint"
  detail?: string;
}

const { milestone, detail } = Astro.props;
---

<div class="coming-soon">
  <p class="marker">Coming in the {milestone}</p>
  {detail && <p class="detail">{detail}</p>}
</div>

<style>
  .coming-soon {
    background: var(--color-paper);
    border: 1px solid var(--color-cream-deep);
    border-radius: var(--radius-3);
    padding: var(--space-8);
    text-align: center;
    max-width: var(--max-width-prose);
  }

  .marker {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-xs);
    letter-spacing: var(--letter-spacing-kicker);
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .detail {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    line-height: var(--line-height-relaxed);
    margin: var(--space-4) 0 0;
  }
</style>
